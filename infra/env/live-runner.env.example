# live-runner

RUNNER_ADDR=:8080
PUBLIC_HOST=localhost:8088
PUBLIC_URL_SCHEME=http
TEMP_DIR=/tmp/live
PRESETS_FILE=/etc/runner/presets/live.yaml
DEFAULT_LIVE_PRESET=default
BROKER_AUTH_TOKEN=
RTMP_PUBLIC_HOST=localhost
RUNNER_INGEST_PUBLIC_HOST=localhost
RUNNER_SHARED_INGEST_ADDR=:1935
RTMP_LISTEN_HOST=0.0.0.0
RTMP_PORT_START=19350
RTMP_PORT_END=19449
SESSION_NO_PUBLISH_TTL=2m
SESSION_IDLE_TTL=30s
BROKER_CALLBACK_TIMEOUT=5s
SESSION_HEARTBEAT_INTERVAL=10s
SESSION_USAGE_TICK_INTERVAL=5s
OUTPUT_SYNC_INTERVAL=250ms
OUTPUT_FAILURE_THRESHOLD=3
FFMPEG_BIN=ffmpeg
