# registry / image selection
REGISTRY=tztcloud
TAG=v1.3.0

# exposed ports
TRANSCODE_RUNNER_PORT=8086
ABR_RUNNER_PORT=8087

# preset files mounted from infra/presets
TRANSCODE_PRESETS_FILE=nvidia-gtx1080-transcode.yaml
ABR_PRESETS_FILE=nvidia-gtx1080-abr.yaml

# queue sizing
TRANSCODE_MAX_QUEUE_SIZE=2
ABR_MAX_QUEUE_SIZE=1

# job retention in memory
TRANSCODE_JOB_TTL_SECONDS=3600
ABR_JOB_TTL_SECONDS=3600

# docker logging
LOG_MAX_SIZE=10m
LOG_MAX_FILE=5

# nvidia runtime
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,video,utility
NVIDIA_DEVICE_COUNT=1

# optional container names
TRANSCODE_CONTAINER_NAME=transcode-runner
ABR_CONTAINER_NAME=abr-runner
